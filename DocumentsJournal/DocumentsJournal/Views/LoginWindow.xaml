<Window x:Class="DocumentsJournal.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="592" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA"
        MinHeight="500" MinWidth="400">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="175*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="66*"/>
            <ColumnDefinition Width="215*"/>
            <ColumnDefinition Width="101*"/>
            <ColumnDefinition Width="118*"/>
        </Grid.ColumnDefinitions>
        <!-- Верхний фон -->
        <Border Background="#1A365D" Height="220" VerticalAlignment="Top" Grid.ColumnSpan="4"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="4" Grid.RowSpan="2">
            <StackPanel VerticalAlignment="Center" Margin="30,20,30,20">

                <!-- Логотип -->
                <Border Background="White" CornerRadius="50" Width="90" Height="90" 
                        HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="📋" FontSize="44" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Журнал входящих документов" 
                           FontSize="20" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Администрация Слободского района" 
                           FontSize="13" Foreground="#90E0EF" 
                           HorizontalAlignment="Center" Margin="0,0,0,35"/>

                <!-- Карточка входа -->
                <Border Background="White" CornerRadius="12" Padding="30,25" 
                        BorderBrush="#E2E8F0" BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <TextBox x:Name="txtEmail" Text="tekashinick@gmail.com" 
                                 Height="44" FontSize="14" Padding="12,0"
                                 Margin="0,0,0,20"/>

                        <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <PasswordBox x:Name="txtPassword" 
                                     Height="44" FontSize="14" Padding="12,0"
                                     Margin="0,0,0,25"/>

                        <TextBlock x:Name="tbStatus" FontSize="12" Foreground="#FF6B35" 
                                   Margin="0,0,0,10" HorizontalAlignment="Center" Height="20"/>

                        <Button x:Name="btnLogin" Content="ВОЙТИ" 
                                Background="#00B4D8" Foreground="White"
                                Height="50" FontSize="15" FontWeight="Bold"
                                Margin="0,0,0,12" Cursor="Hand"/>

                        <Button x:Name="btnRegister" Content="РЕГИСТРАЦИЯ" 
                                Background="#1A365D" Foreground="White"
                                Height="50" FontSize="15" FontWeight="Bold"
                                Margin="0,0,0,15" Cursor="Hand"/>

                        <ProgressBar x:Name="progressBar" Height="4" Margin="0,5,0,0" 
                                     IsIndeterminate="True" Visibility="Collapsed"
                                     Foreground="#00B4D8"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>