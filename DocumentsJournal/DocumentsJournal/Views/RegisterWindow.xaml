<Window x:Class="DocumentsJournal.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="736" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        WindowStyle="SingleBorderWindow"
        Background="#F5F7FA"
        MinHeight="550" MinWidth="450">

    <Grid Margin="0,0,0,-67">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78*"/>
            <ColumnDefinition Width="47*"/>
        </Grid.ColumnDefinitions>
        <Border Background="#1A365D" Height="180" VerticalAlignment="Top" Grid.ColumnSpan="2"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,66" Grid.ColumnSpan="2">
            <StackPanel VerticalAlignment="Center" Margin="30,20,30,20">

                <Border Background="White" CornerRadius="50" Width="80" Height="80" 
                        HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock Text="📋" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Border Background="White" CornerRadius="12" Padding="30,25" 
                        BorderBrush="#E2E8F0" BorderThickness="1">

                    <StackPanel>
                        <TextBlock Text="ФИО" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <TextBox x:Name="txtFullName" Height="44" FontSize="14" Padding="12,0" Margin="0,0,0,15"/>

                        <TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <TextBox x:Name="txtEmail" Height="44" FontSize="14" Padding="12,0" Margin="0,0,0,15"/>

                        <TextBlock Text="Пароль" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <PasswordBox x:Name="txtPassword" Height="44" FontSize="14" Padding="12,0" Margin="0,0,0,5"/>
                        <TextBlock Text="Минимум 6 символов" FontSize="11" Foreground="#94A3B8" Margin="0,0,0,15"/>

                        <TextBlock Text="Подтверждение пароля" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#1A365D" FontSize="14"/>
                        <PasswordBox x:Name="txtConfirmPassword" Height="44" FontSize="14" Padding="12,0" Margin="0,0,0,20"/>

                        <TextBlock x:Name="tbStatus" FontSize="12" Foreground="#FF6B35" 
                                   Margin="0,0,0,10" HorizontalAlignment="Center" Height="20"/>

                        <Button x:Name="btnRegister" Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                                Background="#00B4D8" Foreground="White"
                                Height="50" FontSize="15" FontWeight="Bold"
                                Margin="0,0,0,12" Cursor="Hand"/>

                        <Button x:Name="btnBack" Content="НАЗАД" 
                                Background="#1A365D" Foreground="White"
                                Height="50" FontSize="15" FontWeight="Bold"
                                Margin="0,0,0,15" Cursor="Hand"/>

                        <ProgressBar x:Name="progressBar" Height="4" Margin="0,5,0,0" 
                                     IsIndeterminate="True" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>