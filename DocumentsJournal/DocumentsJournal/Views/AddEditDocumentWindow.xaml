<Window x:Class="DocumentsJournal.Views.AddEditDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Документ"
        Height="650" Width="750"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#1A365D"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A365D" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <TextBlock x:Name="tbTitle" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Регистрационные данные -->
                <GroupBox Header="📌 Регистрационные данные">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Входящий №:*" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <TextBox x:Name="txtIncomingNumber" Grid.Row="0" Grid.Column="1"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Дата поступления:*" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <DatePicker x:Name="dpDateReceived" Grid.Row="1" Grid.Column="1"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Отправитель:*" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <TextBox x:Name="txtSender" Grid.Row="2" Grid.Column="1"/>

                        <Label Grid.Row="3" Grid.Column="0" Content="Тип документа:" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbDocumentType" Grid.Row="3" Grid.Column="1">
                            <ComboBoxItem Content="Письмо"/>
                            <ComboBoxItem Content="Заявление"/>
                            <ComboBoxItem Content="Жалоба"/>
                            <ComboBoxItem Content="Предложение"/>
                            <ComboBoxItem Content="Запрос"/>
                            <ComboBoxItem Content="Постановление"/>
                            <ComboBoxItem Content="Договор"/>
                            <ComboBoxItem Content="Иное"/>
                        </ComboBox>

                        <Label Grid.Row="4" Grid.Column="0" Content="Краткое содержание:*" VerticalAlignment="Top" Foreground="#1A365D" FontWeight="Bold"/>
                        <TextBox x:Name="txtSummary" Grid.Row="4" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Grid>
                </GroupBox>

                <!-- Исполнение -->
                <GroupBox Header="⚙️ Исполнение">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Исполнитель:" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <TextBox x:Name="txtExecutor" Grid.Row="0" Grid.Column="1"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Срок исполнения:" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <DatePicker x:Name="dpExecutionDeadline" Grid.Row="1" Grid.Column="1"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Статус:" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbStatus" Grid.Row="2" Grid.Column="1">
                            <ComboBoxItem Content="На рассмотрении"/>
                            <ComboBoxItem Content="В работе"/>
                            <ComboBoxItem Content="На исполнении"/>
                            <ComboBoxItem Content="Исполнен"/>
                            <ComboBoxItem Content="Снят с контроля"/>
                            <ComboBoxItem Content="Отказ"/>
                        </ComboBox>

                        <Label Grid.Row="3" Grid.Column="0" Content="На контроле:" VerticalAlignment="Center" Foreground="#1A365D" FontWeight="Bold"/>
                        <CheckBox x:Name="chkIsControlled" Grid.Row="3" Grid.Column="1" IsChecked="True"/>

                        <Label Grid.Row="4" Grid.Column="0" Content="Примечания:" VerticalAlignment="Top" Foreground="#1A365D" FontWeight="Bold"/>
                        <TextBox x:Name="txtNotes" Grid.Row="4" Grid.Column="1" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" Background="#00B4D8" Foreground="White" Width="120"/>
            <Button x:Name="btnCancel" Content="❌ Отмена" Background="#1A365D" Foreground="White" Width="120" Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>